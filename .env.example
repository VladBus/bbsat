# BBSAT Environment Variables
# Скопируйте этот файл как .env и заполните реальными значениями
# Файл .env исключён из Git (.gitignore) и не попадёт в репозиторий

# =============================================================================
# EMAIL CONFIGURATION
# Настройки SMTP сервера для отправки отчётов
# =============================================================================

# Пароль от почты для отправки отчётов
# Получите у администратора почтового сервера
BBSAT_EMAIL_PASSWORD=your_password_here

# =============================================================================
# SMTP SERVER SETTINGS (опционально)
# Измените если ваш SMTP сервер отличается от стандартного
# =============================================================================

# SMTP сервер (по умолчанию: zmail.aari.ru)
# BBSAT_SMTP_SERVER=zmail.aari.ru

# SMTP порт (по умолчанию: 465 для SSL)
# BBSAT_SMTP_PORT=465

# Адрес отправителя (по умолчанию: vvbusev@aari.ru)
# BBSAT_ADDR_FROM=vvbusev@aari.ru

# =============================================================================
# PATHS (опционально)
# Измените если пути к данным отличаются от стандартных
# =============================================================================

# Путь к базовой директории с продуктами спутников
# BBSAT_PRODUCTS_PATH=S:\Products

# Путь к архиву обработанных GeoTIFF файлов
# BBSAT_GEOTIF_PATH=S:\GeoTif

# Путь к файлам траекторий (.trk)
# BBSAT_TRK_PATH=S:\trk

# Путь к директории для отчётов
# BBSAT_REPORTS_PATH=S:\reports

# Путь к локальной корзине для битых файлов
# BBSAT_TRASH_PATH=D:\temp_trash

# =============================================================================
# LOGGING SETTINGS (опционально)
# =============================================================================

# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
# BBSAT_LOG_LEVEL=INFO

# =============================================================================
# SCHEDULE SETTINGS (опционально)
# =============================================================================

# Время ежедневной очистки (по умолчанию: 00:01)
# BBSAT_CLEANUP_TIME=00:01

# Время ежедневной сортировки (по умолчанию: 00:05)
# BBSAT_SORT_TIME=00:05

# Время ежедневной компрессии (по умолчанию: 00:30)
# BBSAT_COMPRESS_TIME=00:30

# Время сбора статистики (по умолчанию: 02:25)
# BBSAT_STATISTIC_TIME=02:25

# Время отправки отчёта (по умолчанию: среда 02:45)
# BBSAT_SEND_DAY=Wednesday
# BBSAT_SEND_TIME=02:45
