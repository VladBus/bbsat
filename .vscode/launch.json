{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Python: Текущий файл (bbsat)",
			"type": "debugpy",
			"request": "launch",
			"program": "${file}",
			"console": "integratedTerminal",
			"justMyCode": true,
			"env": {
				"PYTHONPATH": "${workspaceFolder}"
			}
		},
		{
			"name": "Python: Главный вход (main.py)",
			"type": "debugpy",
			"request": "launch",
			"program": "${workspaceFolder}/main.py",
			"console": "integratedTerminal"
		}
	]
}
