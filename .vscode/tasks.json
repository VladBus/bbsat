{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Install Requirements",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/pip install -r requirements.txt",
			"group": "build"
		},
		{
			"label": "Clean Pycache",
			"type": "shell",
			"command": "find . -name '__pycache__' -type d -exec rm -rf {} +", // Для Linux/Mac
			"windows": {
				"command": "for /d /r . %d in (__pycache__) do @if exist \"%d\" rd /s /q \"%d\""
			},
			"problemMatcher": []
		}
	]
}
